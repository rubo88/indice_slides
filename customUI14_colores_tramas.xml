<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui">
  <ribbon>
    <tabs>
      <tab id="tabTemasGraficos" label="Temas Gráficos">
        <group id="grpAplicar" label="Aplicar Tema">
          <button id="btnAplicadorTemas"
                  label="Aplicador de Temas"
                  onAction="RibbonAplicadorDeTemas"
                  imageMso="ChartTypeColumnInsert"
                  size="large"
                  screentip="Abrir Aplicador de Temas"
                  supertip="Abre el formulario para seleccionar y aplicar un tema de colores y tramas a los gráficos." />
        </group>
        <group id="grpFondoBlanco" label="Fondo Blanco">
          <button id="btnBlancoActivo"
                  label="Gráfico Activo"
                  onAction="RibbonTema_FondoBlanco_AlGraficoActivo"
                  imageMso="ChartTypeAllInsert"
                  size="normal"
                  screentip="Fondo Blanco — Gráfico Activo"
                  supertip="Aplica el tema Fondo Blanco al gráfico seleccionado." />
          <button id="btnBlancoTodos"
                  label="Todos (Hoja)"
                  onAction="RibbonTema_FondoBlanco_A_Todos_LaHoja"
                  imageMso="ChartStyleGallery"
                  size="normal"
                  screentip="Fondo Blanco — Todos los Gráficos"
                  supertip="Aplica el tema Fondo Blanco a todos los gráficos de la hoja activa." />
        </group>
        <group id="grpFondoAzul" label="Fondo Azul">
          <button id="btnAzulActivo"
                  label="Gráfico Activo"
                  onAction="RibbonTema_FondoAzul_AlGraficoActivo"
                  imageMso="ChartTypeAllInsert"
                  size="normal"
                  screentip="Fondo Azul — Gráfico Activo"
                  supertip="Aplica el tema Fondo Azul al gráfico seleccionado." />
          <button id="btnAzulTodos"
                  label="Todos (Hoja)"
                  onAction="RibbonTema_FondoAzul_A_Todos_LaHoja"
                  imageMso="ChartStyleGallery"
                  size="normal"
                  screentip="Fondo Azul — Todos los Gráficos"
                  supertip="Aplica el tema Fondo Azul a todos los gráficos de la hoja activa." />
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
